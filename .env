# Door Monitor Configuration

# The ntfy.sh channel name to send notifications to
NTFY_CHANNEL_ID=your-channel-name

# How often to check for door status changes (seconds)
POLLING_INTERVAL_SECONDS=.5

# How long a door must be open before a notification is sent (minutes)
DOOR_OPEN_THRESHOLD_MINUTES=10.0

# How often to repeat the notification if the door stays open (seconds)
NOTIFICATION_REPEAT_INTERVAL_SECONDS=60.0

# MAC addresses to completely ignore (comma separated)
BLUETOOTH_DENYLIST=D1:C1:5A:B7:5D:86,69:57:7E:5C:4E:EF,75:8C:BF:D3:58:4F,EE:2D:C2:86:66:8B,18:3B:5C:A3:A6:66,D3:72:02:7A:02:C1,DE:95:93:99:92:99,D2:4D:0C:CB:E0:A2,00:24:B1:0D:66:53,43:95:CF:28:12:07,2E:99:46:09:FE:F3,E2:BB:9E:2B:02:97,E2:46:FE:3D:1B:51,0C:DD:F2:F2:32:47,6E:2A:98:BC:A3:AE,40:F3:B0:89:32:60,43:E7:EB:63:32:64,43:66:8C:39:E5:55,6F:51:E3:39:EF:D5,70:34:B0:5E:09:40,B8:27:EB:44:26:29,5B:60:F9:0A:C0:21,66:3D:54:C2:C5:C4,6E:E8:2B:24:E6:71,71:E8:4F:34:B7:28,72:0F:CD:98:86:82,75:BE:44:FC:C8:D0,79:31:A2:52:C0:B8,D7:84:36:C5:3E:19,DD:43:AA:89:F8:5E,E9:33:C8:66:90:09,65:61:0F:AD:DE:DD
